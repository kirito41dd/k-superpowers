#!/usr/bin/env bash
# Resolve and ensure the working-tree directory SDD uses for short-lived
# artifacts: task briefs, implementer reports, review packages, and the
# progress ledger. Print the directory's absolute path.
#
# The workspace lives in the working tree, not under .git, because some
# harnesses protect .git from agent writes. A self-ignoring .gitignore keeps
# these artifacts out of git status and accidental commits.
set -euo pipefail

root=$(git rev-parse --show-toplevel)
dir="$root/.superpowers/sdd"
mkdir -p "$dir"
printf '*\n' > "$dir/.gitignore"
cd "$dir" && pwd
