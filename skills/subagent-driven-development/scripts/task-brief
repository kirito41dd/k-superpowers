#!/usr/bin/env bash
# Extract one task's full text from an implementation plan into a file the
# implementer reads in one call, so task text does not stay resident in the
# controller's context.
#
# Usage: task-brief PLAN_FILE TASK_NUMBER [OUTFILE]
# Default OUTFILE: <repo-root>/.superpowers/sdd/task-<N>-brief.md
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "usage: task-brief PLAN_FILE TASK_NUMBER [OUTFILE]" >&2
  exit 2
fi

plan=$1
n=$2
[ -f "$plan" ] || { echo "no such plan file: $plan" >&2; exit 2; }

if [ $# -eq 3 ]; then
  out=$3
else
  dir=$("$(cd "$(dirname "$0")" && pwd)/sdd-workspace")
  out="$dir/task-${n}-brief.md"
fi

global_constraints=$(awk '
  /^```/ { infence = !infence }
  !infence && /^##[ \t]+Global Constraints[ \t]*$/ {
    insection = 1
    next
  }
  !infence && insection && /^##[ \t]+/ { exit }
  insection { print }
' "$plan")

task_text=$(awk -v n="$n" '
  /^```/ { infence = !infence }
  !infence && /^#+[ \t]+Task[ \t]+[0-9]+/ {
    intask = ($0 ~ ("^#+[ \t]+Task[ \t]+" n "([^0-9]|$)"))
  }
  intask { print }
' "$plan")

if [ -z "$task_text" ]; then
  echo "task ${n} not found in ${plan} (no heading matching 'Task ${n}')" >&2
  exit 3
fi

{
  printf "# Task %s Brief\n\n" "$n"
  printf "## Global Constraints\n\n"
  if [ -n "$global_constraints" ]; then
    printf "%s\n\n" "$global_constraints"
  else
    printf "None (no ## Global Constraints section found in plan)\n\n"
  fi
  printf "## Task\n\n"
  printf "%s\n" "$task_text"
} > "$out"

echo "wrote ${out}: $(wc -l < "$out" | tr -d ' ') lines"
